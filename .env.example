# OpenRouter (primary)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_MODEL=google/gemini-2.5-flash

# Ollama (local fallback for tests)
OLLAMA_MODEL=qwen3:1.7b

# Other app settings
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
DATABASE_URL=postgresql://postgres:apex@localhost/apex_ledger
APPLICANT_REGISTRY_URL=postgresql://postgres:apex@localhost/apex_ledger
DOCUMENTS_DIR=./documents
REGULATION_VERSION=2026-Q1
LOG_LEVEL=INFO
LEDGER_API_KEYS=viewer=dev-viewer-key,reviewer=dev-reviewer-key,compliance=dev-compliance-key,analyst=dev-analyst-key,admin=dev-admin-key
NEXT_PUBLIC_LEDGER_API_KEY=dev-viewer-key
